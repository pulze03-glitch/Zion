# Copy this file to .env and fill in your YouTube API key.
# Never commit .env to git.

# Get a key at https://console.cloud.google.com
# Enable "YouTube Data API v3" then create an API key (no referrer restrictions needed for server-side use)
YOUTUBE_API_KEY=AIzaSy_REPLACE_ME

# Port the server listens on (Railway sets this automatically)
PORT=3001
